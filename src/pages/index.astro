---
import Base from '../layouts/Base.astro';
import '../styles/main.css';

const postFiles = import.meta.glob('./**/index.mdx', { eager: true });
const posts = (Object.values(postFiles) as any[]).filter(
  (post) => !post.frontmatter.draft
);
const sorted = posts.sort(
  (a, b) => new Date(b.frontmatter.date) - new Date(a.frontmatter.date)
);
const fmtDate = (d: string) => new Date(d).toISOString().slice(0, 10);
---

<Base title="Wurtle's Blog">
  <article>
    <header class="masthead">
      <h1>Wurtle's Blog</h1>
      <p class="tagline">Notes on math, code, and other curiosities.</p>
    </header>
    <section class="post-list">
      {sorted.map((post) => (
        <a class="post-entry" href={post.url}>
          <time datetime={fmtDate(post.frontmatter.date)}>
            {fmtDate(post.frontmatter.date)}
          </time>
          <span>
            <span class="post-entry-title">{post.frontmatter.title}</span>
            {post.frontmatter.description && (
              <span class="post-entry-desc">{post.frontmatter.description}</span>
            )}
          </span>
        </a>
      ))}
    </section>
  </article>
</Base>
